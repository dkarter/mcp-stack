BIND_ADDRESS=127.0.0.1
GATEWAY_PORT=8080
PROXY_INTERNAL_PORT=8080

INTERNAL_PORT=8000
CONTEXT7_EXT_PORT=8047
CONTEXT7_HEALTH_PORT=8000

GITHUB_MCP_EXT_PORT=8048
GITHUB_MCP_INTERNAL_PORT=8082

MCP_GATEWAY_EXT_PORT=8049
MCP_GATEWAY_INTERNAL_PORT=8090
GATEWAY_HOST=host.docker.internal

# Secret storage backend for host gateway.
# fnox (default) stores tokens in keychain via fnox.
# sqlite stores tokens in gateway SQLite DB.
SECRET_BACKEND=fnox

E2B_MCP_EXT_PORT=8050
E2B_MCP_INTERNAL_PORT=8083

# Secrets are intentionally NOT stored in .env.
# Set them in fnox and run commands with `fnox exec ...` (or use mise tasks).
# Expected secret env vars:
# - CONTEXT7_API_KEY
# - E2B_API_KEY
# - GITHUB_PERSONAL_ACCESS_TOKEN

# Optional: for providers requiring manual OAuth client registration.
# Use <UPSTREAM_NAME>_OAUTH_CLIENT_ID and <UPSTREAM_NAME>_OAUTH_CLIENT_SECRET
# where <UPSTREAM_NAME> matches the name you add in the registry UI.
# Example for upstream name "acme":
# ACME_OAUTH_CLIENT_ID=
# ACME_OAUTH_CLIENT_SECRET=

# Optional OAuth client credentials for specific upstreams should also come from fnox exec env.
